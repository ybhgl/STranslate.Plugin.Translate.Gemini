    <sys:String x:Key="STranslate_Plugin_Translate_STranslate.Plugin.Translate.Gemini_ApiKey">密钥</sys:String>
    <sys:String x:Key="STranslate_Plugin_Translate_STranslate.Plugin.Translate.Gemini_ApiKey_Placeholder">请输入密钥</sys:String>
    <sys:String x:Key="STranslate_Plugin_Translate_STranslate.Plugin.Translate.Gemini_ApiKey_Description">输入您的 Gemini API 密钥</sys:String>
    <sys:String x:Key="STranslate_Plugin_Translate_STranslate.Plugin.Translate.Gemini_Model">请选择模型</sys:String>
    <sys:String x:Key="STranslate_Plugin_Translate_STranslate.Plugin.Translate.Gemini_Prompt_Header">提示词配置</sys:String>
